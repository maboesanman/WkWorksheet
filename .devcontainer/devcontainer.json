{
  "name": "Kanji LaTeX",
  "build": { "dockerfile": "../Dockerfile" },
  "customizations": {
    "vscode": {
      "extensions": [
        "james-yu.latex-workshop",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "postCreateCommand": "pip install --break-system-packages -r requirements.txt && python3 -m ipykernel install --user --name=wkworksheet --display-name='Python 3 (WkWorksheet)'"
