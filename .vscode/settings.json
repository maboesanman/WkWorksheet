{
  "latex-workshop.latex.outDir": "%DIR%/out",
    // Tell LaTeX Workshop to use XeLaTeX
  "latex-workshop.latex.recipes": [
    {
      "name": "XeLaTeX",
      "tools": ["xelatex"]
    }
  ],

  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-shell-escape",
        "-interaction=nonstopmode",
        "-synctex=1",
        "%DOCFILE%"
      ]
    }
  ],

  // Optional: show PDF preview in VS Code tab
  "latex-workshop.view.pdf.viewer": "tab",
}